{
  "$comment": "Project-specific config for the SDLC orchestrator. Read by hook scripts and slash commands. NOT read by the Claude Code harness itself (that's .claude/settings.json).",
  "screenshots": {
    "reference_dir": ".claude/screenshots/reference",
    "feedback_dir": ".claude/screenshots/feedback",
    "current_state_dir": ".claude/screenshots/feedback/current-state",
    "iterations_dir": ".claude/screenshots/feedback/iterations",
    "max_iterations": 3,
    "auto_capture": true,
    "pages_to_capture": [
      "/",
      "/products",
      "/cart",
      "/checkout",
      "/dashboard",
      "/login",
      "/signup"
    ]
  },
  "context": {
    "dir": ".claude/context",
    "files": {
      "plan": ".claude/context/plan-output.md",
      "jira": ".claude/context/jira-output.md",
      "adr": ".claude/context/adr-output.md",
      "ux": ".claude/context/ux-output.md",
      "backend": ".claude/context/backend-output.md",
      "frontend": ".claude/context/frontend-output.md",
      "qa": ".claude/context/qa-output.md",
      "deploy": ".claude/context/deploy-output.md",
      "develop": ".claude/context/develop-output.md",
      "cicd": ".claude/context/cicd-output.md",
      "review": ".claude/context/review-output.md"
    }
  },
  "security": {
    "block_env_commit": true,
    "block_secret_hardcode": true,
    "scan_on_write": true,
    "blocked_patterns": [
      ".env",
      ".env.local",
      ".env.production",
      ".env.staging",
      ".env.development",
      ".env.test"
    ]
  },
  "commit": {
    "convention": "<JIRA-ID>:<Type>/<short description>",
    "require_jira_ticket": true,
    "subject_pattern": "^[A-Z][A-Z0-9]+-[0-9]+:(Feature|Bugfix|Hotfix|Chore|Refactor|Docs|Test|Task)/.+",
    "allowed_types": ["Feature", "Bugfix", "Hotfix", "Chore", "Refactor", "Docs", "Test", "Task"],
    "jira_type_to_commit_type": {
      "Story": "Feature",
      "Epic": "Feature",
      "Bug": "Bugfix",
      "Task": "Task",
      "Sub-task": "Task",
      "Subtask": "Task"
    }
  },
  "jira": {
    "$comment": "Project policy for any command/agent that touches Jira via the Atlassian MCP. Canonical reference: .claude/lib/core/jira-policy.md",
    "policy_doc": ".claude/lib/core/jira-policy.md",
    "ownership": {
      "only_modify_own_issues": true,
      "skip_if_assignee_mismatch": true,
      "jql_must_include_current_user": true,
      "jql_template": "assignee = currentUser() AND statusCategory != Done"
    },
    "assignee": {
      "always_assign_to_current_user": true,
      "lookup_order": [
        "jira-board.json#assignee.account_id",
        "mcp.lookupJiraAccountId(email=jira-board.json#assignee.email)",
        "mcp.atlassianUserInfo"
      ],
      "post_create_fixup_if_unassigned": true
    },
    "hierarchy": {
      "create_order": ["Epic", "Story", "Task", "Subtask", "Bug"],
      "epic_per_plan": 1,
      "subtasks_per_story": ["backend", "frontend", "tests", "deploy-docs"],
      "subtasks_per_task": ["implementation", "tests"],
      "drop_inapplicable_subtasks": true
    },
    "backlog": {
      "place_in_backlog": true,
      "never_set_sprint_field": true,
      "preserve_existing_sprint_on_update": true
    },
    "status_transitions": {
      "$comment": "Phase → target status. The runtime resolves each name against the project's real workflow via getTransitionsForJiraIssue and caches the mapping in jira-board.json#transitions.",
      "jira_create": "To Do",
      "adr_complete": null,
      "ux_complete": null,
      "develop_start": "In Progress",
      "develop_done": "In Review",
      "cicd_complete": null,
      "review_pass": "Done",
      "review_fail": "In Progress",
      "demo_complete": "Done"
    },
    "refusal_lines": {
      "assignee_mismatch": "⚠️  Skipping <KEY> — assigned to <displayName>, not you. Project policy: only modify your own issues.",
      "unassigned": "⚠️  Skipping <KEY> — unassigned. Project policy: only modify your own issues.",
      "unknown_assignee": "⚠️  Skipping <KEY> — assigned to no one (or unable to read assignee). Project policy: only modify your own issues."
    }
  }
}
