# Supabase project URL (public — safe to expose in client code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (public — safe to expose in client code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER ONLY.
# NEVER expose this to the browser. Used only for the organizer-seeding
# SQL helper and any server-side operations that must bypass RLS.
# At runtime (app) this env var is OPTIONAL — the app uses the anon key
# via the authenticated session. Only needed if you use createAdminClient().
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Test / QA environment (NEVER set in production) ──────────────────────────
# Separate Supabase project or schema used exclusively by the test suite.
# DB tests (npm run test:db) require these three vars.
# E2e tests (npm run test:e2e) use NEXT_PUBLIC_SUPABASE_URL + SUPABASE_TEST_SERVICE_ROLE_KEY.
SUPABASE_TEST_URL=https://your-test-project-ref.supabase.co
SUPABASE_TEST_ANON_KEY=your-test-anon-key-here
SUPABASE_TEST_SERVICE_ROLE_KEY=your-test-service-role-key-here
